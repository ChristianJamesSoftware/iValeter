// ─────────────────────────────────────────────────────────────────────────────
// SERVICE CHARGE REQUESTS
// Raised automatically when a customer booking includes a chargeable add-on
// (Paint Protection, CSI Add-On, Work Clothes, etc.).
// SA approves → line added to valeter's timesheet extra lines for that week
// → included in the weekly client bill.
// ─────────────────────────────────────────────────────────────────────────────

enum ServiceChargeType {
  PAINT_PROTECTION   // Paint Protection Sales — nominal 202
  CSI_ADDON          // CSI Sales Add-Ons — nominal 203
  WORK_CLOTHES       // Work Clothes — nominal 323
  SUBCONTRACTOR      // Subcontractor Wages — nominal 321
  OTHER              // Catch-all for manually raised charges
}

enum ServiceChargeStatus {
  PENDING
  APPROVED
  REJECTED
}

/// A chargeable service item raised against a booking, pending SA approval.
/// On approval, written to TimesheetExtraLine for the valeter's week
/// and included in the next client invoice.
model ServiceChargeRequest {
  id             String              @id @default(cuid())
  organisationId String
  organisation   Organisation        @relation(fields: [organisationId], references: [id])

  /// The booking that triggered this charge (may be null for manual charges)
  bookingId      String?
  booking        Booking?            @relation(fields: [bookingId], references: [id])

  /// The valeter who performed the work (used to find their timesheet)
  userId         String
  user           User                @relation("ServiceChargeRequests", fields: [userId], references: [id])

  siteId         String?
  site           Site?               @relation(fields: [siteId], references: [id])

  type           ServiceChargeType
  description    String              // e.g. "Paint Protection — Porsche Cayenne AB21 XYZ"
  amountPence    Int                 // charge to the client (inc. or exc. VAT per taxType)

  /// ISO week start (Monday) this charge belongs to
  weekStarting   DateTime

  status         ServiceChargeStatus @default(PENDING)
  reviewedByUserId String?
  reviewedAt     DateTime?
  reviewNote     String?

  /// Set once written to timesheet extra lines
  timesheetExtraLineId String?

  /// Xero nominal code for this charge type (resolved on approval)
  xeroNominalCodeId    String?
  xeroNominalCode      XeroExpenseNominalCode? @relation(fields: [xeroNominalCodeId], references: [id])

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organisationId])
  @@index([userId])
  @@index([bookingId])
  @@index([weekStarting])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// CSI SENSORY STANDARD ADD-ONS
// Global add-on catalogue (managed by super admin).
// DealershipAddOn tracks which add-ons are enabled per dealership.
// ─────────────────────────────────────────────────────────────────────────────

model AddOn {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dealershipAddOns DealershipAddOn[]
}

model DealershipAddOn {
  id           String   @id @default(cuid())
  dealershipId String
  addOnId      String
  enabled      Boolean  @default(false)
  priceGbp     Float?   // price charged to this dealership; null = not set yet
  updatedAt    DateTime @updatedAt

  dealership Dealership @relation(fields: [dealershipId], references: [id])
  addOn      AddOn      @relation(fields: [addOnId], references: [id])

  @@unique([dealershipId, addOnId])
  @@index([dealershipId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM VALET TYPE LIBRARY
// Master list managed by super admin; dealerships select from these
// ─────────────────────────────────────────────────────────────────────────────

enum ValetDepartmentType {
  SALES
  SERVICE
  BODYSHOP
  HIRE
  ALL
}

model ValetTypeTemplate {
  id               String              @id @default(cuid())
  name             String              @unique
  valetCode        String?             @unique // Short internal code, e.g. "PD01"
  nominalCode      String?             // Xero/accounting nominal code, e.g. "4001"
  description      String?
  category         ServiceCategory     @default(VALET)
  departmentType   ValetDepartmentType @default(ALL) // Links to Sales, Service, Bodyshop, or All
  defaultDurationMins Int              @default(60)
  isActive         Boolean             @default(true)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM RATE TEMPLATES
// Master rate templates managed by super admin; dealerships select one
// ─────────────────────────────────────────────────────────────────────────────

model RateTemplate {
  id           String   @id @default(cuid())
  name         String   @unique   // e.g. "Standard Retail", "Premium Franchise"
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
