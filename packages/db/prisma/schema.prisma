// ─────────────────────────────────────────────────────────────────────────────
// BOOKING
// Extended: priorityLevel, keyNumber, vehicleLocation, notification fields
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id             String      @id @default(cuid())
  organisationId String
  siteId         String
  site           Site        @relation(fields: [siteId], references: [id])
  departmentId   String
  department     Department  @relation(fields: [departmentId], references: [id])
  serviceTypeId  String
  serviceType    ServiceType @relation(fields: [serviceTypeId], references: [id])

  vehicleReg      String
  vehicleMake     String?
  vehicleModel    String?
  vehicleColour   String?
  customerName    String
  keyNumber       String?
  vehicleLocation String?

  status        BookingStatus @default(PENDING)
  isPriority    Boolean       @default(false)
  priorityLevel PriorityLevel @default(STANDARD)
  readyByTime   DateTime

  // Phase 2 add-ons (existing)
  includeInspection      Boolean @default(false)
  inspectionComplete     Boolean @default(false)
  includeFreshScent      Boolean @default(false)
  paintProtectionTier    String?
  freshScentConfirmed    Boolean @default(false)
  paintProtectionApplied Boolean @default(false)
  photographyPackage     String?

  includeInspection      Boolean @default(false)
  inspectionComplete     Boolean @default(false)
  includeFreshScent      Boolean @default(false)
  paintProtectionTier    String? // null | "essential" | "standard" | "premium" | "ultimate"
  freshScentConfirmed    Boolean @default(false)
  paintProtectionApplied Boolean @default(false)
  photographyPackage     String? // null | "standard" | "premium" | "full"

  assignedToId String?
  assignedTo   User?   @relation("AssignedValeter", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User    @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Completion notification
  notifyEmail                String?
  notifyPhone                String?
  completionNotificationSent Boolean @default(false)

  // Customer review note
  customerReviewNote String?

  statusHistory JobStatusHistory[]
  photos        JobPhoto[]
  complaints    Complaint[]

  @@index([organisationId])
  @@index([siteId])
  @@index([departmentId])
  @@index([assignedToId])
  @@index([status])
  @@index([vehicleReg])
  @@index([priorityLevel])
}

enum BookingStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  QC_CHECK
  COMPLETED
  CANCELLED
}

enum PriorityLevel {
  STANDARD
  PRIORITY
  URGENT
}

