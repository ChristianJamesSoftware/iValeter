generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANISATION
// ─────────────────────────────────────────────────────────────────────────────

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  sites            Site[]
  users            User[]
  invoices         Invoice[]
  customerInvoices CustomerInvoice[]
  payRuns          PayRun[]
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE
// Extended: geofence config, billing terms, account manager, customer contact
// ─────────────────────────────────────────────────────────────────────────────

model Site {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  address        String?
  createdAt      DateTime     @default(now())

  // Geofencing — used by PWA clock-in
  geofenceLat          Float?
  geofenceLng          Float?
  geofenceRadiusMetres Int?   @default(100)

  // Customer billing configuration
  billingCycle  BillingCycle @default(WEEKLY)
  paymentTerms  PaymentTerms @default(NET14)
  xeroContactId String?      // Xero Contact ID for invoice push

  // Head-of-business contact (receives weekly review email)
  customerContactName  String?
  customerContactEmail String?

  // Account manager from Total Valeting assigned to this site
  accountManagerUserId String?
  accountManager       User?   @relation("AccountManagerSites", fields: [accountManagerUserId], references: [id])

  departments      Department[]
  bookings         Booking[]
  users            User[]         @relation("SiteUsers")
  clockEvents      ClockEvent[]
  timesheets       Timesheet[]
  customerInvoices CustomerInvoice[]
  audits           Audit[]
  weeklyReviews    WeeklyReview[]

  @@index([organisationId])
}

enum BillingCycle {
  WEEKLY
  MONTHLY
}

enum PaymentTerms {
  NET14
  MONTH_END
  MONTH_END_PLUS1
}

// ─────────────────────────────────────────────────────────────────────────────
// DEPARTMENT
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])
  name   String // e.g. Sales, Service, Body Shop

  bookings     Booking[]
  serviceTypes ServiceType[]

  @@index([siteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Extended: staff type, Bankline payroll fields
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  siteId         String?
  site           Site?        @relation("SiteUsers", fields: [siteId], references: [id])
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role
  staffType      StaffType    @default(SITE)
  skills         String[]
  avatarUrl      String?
  phone          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  // NatWest Bankline payroll fields (required for pay run export)
  bankSortCode      String? // 6 digits no dashes e.g. "010203"
  bankAccountNumber String? // 8 digits e.g. "12345678"
  bankAccountName   String? // Name as it appears on bank account
  bankReference     String? // Reference shown on valeter's bank statement e.g. "TOTALVAL WAGES"

  assignedBookings        Booking[]          @relation("AssignedValeter")
  createdBookings         Booking[]          @relation("CreatedBy")
  statusHistory           JobStatusHistory[]
  holidayRequests         HolidayRequest[]
  leaveAllowance          LeaveAllowance?
  clockEvents             ClockEvent[]
  timesheets              Timesheet[]
  payRunLines             PayRunLine[]
  contractorRates         ContractorRate[]
  auditsConducted         Audit[]
  complaintsRectified     Complaint[]        @relation("RectifiedBy")
  complaintsRaised        Complaint[]        @relation("RaisedBy")
  accountManagerSites     Site[]             @relation("AccountManagerSites")
  sentMessages            AccountManagerMessage[] @relation("MessageFrom")
  receivedMessages        AccountManagerMessage[] @relation("MessageTo")

  @@index([organisationId])
  @@index([siteId])
}

enum Role {
  super_admin
  org_admin
  dealership_user
  valeter
}

enum StaffType {
  SITE // Fixed to one site
  SSS  // Site Support Staff — mobile, covers any site
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE TYPE
// Extended: category, customer charge rate, description
// ─────────────────────────────────────────────────────────────────────────────

model ServiceType {
  id           String          @id @default(cuid())
  departmentId String
  department   Department      @relation(fields: [departmentId], references: [id])
  name         String          // e.g. "Service Wash", "Full Valet", "New Car Prep"
  description  String?
  category     ServiceCategory @default(VALET)
  durationMins Int             // Allocated time e.g. 30, 150, 60
  chargeRate   Float?          // Day/job rate charged to customer (GBP, ex-VAT)
  isActive     Boolean         @default(true)

  bookings Booking[]

  @@index([departmentId])
}

enum ServiceCategory {
  VALET    // Service Wash, Full Valet, New Car Prep, Paint Protection
  PAINT    // Machine Polish, Special Polish
  CLEANING // Showroom Clean, Office Clean, Toilet Clean
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKING
// Extended: priority level, key number, vehicle location, notification fields
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id             String      @id @default(cuid())
  organisationId String
  siteId         String
  site           Site        @relation(fields: [siteId], references: [id])
  departmentId   String
  department     Department  @relation(fields: [departmentId], references: [id])
  serviceTypeId  String
  serviceType    ServiceType @relation(fields: [serviceTypeId], references: [id])

  vehicleReg      String
  vehicleMake     String?
  vehicleModel    String?
  vehicleColour   String?
  customerName    String
  keyNumber       String?     // Key tag/fob number
  vehicleLocation String?     // Where on site the vehicle is parked e.g. "Bay 3", "Forecourt Row B"

  status        BookingStatus @default(PENDING)
  priorityLevel PriorityLevel @default(STANDARD)
  readyByTime   DateTime

  assignedToId String?
  assignedTo   User?   @relation("AssignedValeter", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User    @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Completion notifications — sent to whoever made the booking
  notifyEmail                 String?
  notifyPhone                 String?
  completionNotificationSent  Boolean @default(false)

  // Customer review
  customerReviewNote String?

  statusHistory JobStatusHistory[]
  photos        JobPhoto[]
  complaints    Complaint[]

  @@index([organisationId])
  @@index([siteId])
  @@index([departmentId])
  @@index([assignedToId])
  @@index([status])
  @@index([vehicleReg])
  @@index([priorityLevel])
}

enum BookingStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  QC_CHECK
  COMPLETED
  CANCELLED
}

enum PriorityLevel {
  STANDARD
  PRIORITY // Before standard jobs
  URGENT   // Do immediately — notifies team leader
}

model JobStatusHistory {
  id         String        @id @default(cuid())
  bookingId  String
  booking    Booking       @relation(fields: [bookingId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  fromStatus BookingStatus?
  toStatus   BookingStatus
  note       String?
  createdAt  DateTime      @default(now())

  @@index([bookingId])
}

model JobPhoto {
  id        String    @id @default(cuid())
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id])
  url       String
  type      PhotoType @default(AFTER)
  createdAt DateTime  @default(now())

  @@index([bookingId])
}

enum PhotoType {
  BEFORE
  AFTER
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPLAINTS
// Customer raises a complaint against a completed job; team rectifies and closes
// ─────────────────────────────────────────────────────────────────────────────

model Complaint {
  id        String          @id @default(cuid())
  bookingId String
  booking   Booking         @relation(fields: [bookingId], references: [id])

  raisedByUserId String
  raisedBy       User     @relation("RaisedBy", fields: [raisedByUserId], references: [id])
  note           String

  status            ComplaintStatus @default(OPEN)
  rectifiedByUserId String?
  rectifiedBy       User?   @relation("RectifiedBy", fields: [rectifiedByUserId], references: [id])
  rectifiedNote     String?
  rectifiedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RECTIFIED
  CLOSED
}

// ─────────────────────────────────────────────────────────────────────────────
// CLOCK EVENTS
// Raw GPS clock-in/out records from the PWA geofence trigger
// ─────────────────────────────────────────────────────────────────────────────

model ClockEvent {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  siteId            String
  site              Site           @relation(fields: [siteId], references: [id])
  type              ClockEventType
  timestamp         DateTime
  lat               Float?
  lng               Float?
  geofenceTriggered Boolean        @default(false)
  createdAt         DateTime       @default(now())

  @@index([userId])
  @@index([siteId])
  @@index([timestamp])
}

enum ClockEventType {
  CLOCK_IN
  CLOCK_OUT
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTRACTOR RATES
// Pay rate history per valeter — allows rate changes over time
// ─────────────────────────────────────────────────────────────────────────────

model ContractorRate {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  hourlyRate    Float    // Standard hourly rate GBP
  overtimeRate  Float    // Overtime hourly rate GBP
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TIMESHEETS
// Auto-generated Sunday night from ClockEvents; approved by head office;
// sent to customer for 24hr acceptance; feeds into pay run
// ─────────────────────────────────────────────────────────────────────────────

model Timesheet {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id])
  siteId       String
  site         Site   @relation(fields: [siteId], references: [id])
  weekStarting DateTime // Monday 00:00
  weekEnding   DateTime // Sunday 23:59

  totalRegularHours  Float @default(0)
  totalOvertimeHours Float @default(0)

  status TimesheetStatus @default(DRAFT)

  // Head office approval
  approvedByUserId String?
  approvedAt       DateTime?

  // Customer acceptance (24hr window after head office approval)
  sentToCustomerAt   DateTime?
  customerAccepted   Boolean   @default(false)
  customerAcceptedAt DateTime?
  autoAccepted       Boolean   @default(false)
  customerDisputeNote String?

  // Late confirmation — customer signs physical sheet after the fact
  lateConfirmedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines      TimesheetLine[]
  payRunLine PayRunLine?

  @@unique([userId, weekStarting])
  @@index([userId])
  @@index([siteId])
  @@index([status])
}

enum TimesheetStatus {
  DRAFT     // Auto-generated, awaiting valeter review
  SUBMITTED // Valeter reviewed and submitted
  APPROVED  // Head office approved — triggers customer email
  DISPUTED  // Customer raised a query
  LOCKED    // Included in a pay run, immutable
}

model TimesheetLine {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])
  date        DateTime  // The calendar date for this line

  clockInTime  DateTime?
  clockOutTime DateTime?
  breakMins    Int       @default(60) // Default 1 hour lunch

  regularHours  Float @default(0)
  overtimeHours Float @default(0)

  note String?

  @@index([timesheetId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAY RUNS
// Generated Monday, approved by Wednesday, exported to Bankline, paid Friday
// ─────────────────────────────────────────────────────────────────────────────

model PayRun {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  weekStarting   DateTime
  weekEnding     DateTime
  status         PayRunStatus @default(DRAFT)
  exportedAt     DateTime?    // When Bankline .txt was generated
  paidAt         DateTime?    // Confirmed paid on Friday
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines PayRunLine[]

  @@unique([organisationId, weekStarting])
  @@index([organisationId])
}

enum PayRunStatus {
  DRAFT    // Being assembled
  APPROVED // Head office signed off
  EXPORTED // Bankline CSV downloaded
  PAID     // Confirmed paid
}

model PayRunLine {
  id          String    @id @default(cuid())
  payRunId    String
  payRun      PayRun    @relation(fields: [payRunId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  timesheetId String    @unique
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])

  regularHours  Float
  overtimeHours Float
  hourlyRate    Float  // Rate snapshotted at pay run creation
  overtimeRate  Float
  totalAmount   Float  // (regularHours * hourlyRate) + (overtimeHours * overtimeRate)

  // Bankline fields snapshotted so historic exports remain accurate
  bankSortCode      String?
  bankAccountNumber String?
  bankAccountName   String?
  bankReference     String?

  @@index([payRunId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMER INVOICES
// Per-site, per-period; pushed to Xero via API
// ─────────────────────────────────────────────────────────────────────────────

model CustomerInvoice {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])

  periodStart  DateTime
  periodEnd    DateTime
  billingCycle BillingCycle
  paymentTerms PaymentTerms
  dueDate      DateTime

  status    CustomerInvoiceStatus @default(DRAFT)
  totalAmount Float
  currency    String              @default("GBP")

  // Xero integration
  xeroInvoiceId     String?
  xeroInvoiceNumber String?
  xeroSyncedAt      DateTime?

  issuedAt  DateTime?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lineItems CustomerInvoiceLineItem[]

  @@index([organisationId])
  @@index([siteId])
  @@index([status])
}

enum CustomerInvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  DISPUTED
  PAID
  OVERDUE
}

model CustomerInvoiceLineItem {
  id        String          @id @default(cuid())
  invoiceId String
  invoice   CustomerInvoice @relation(fields: [invoiceId], references: [id])

  description String
  quantity    Float
  unitAmount  Float
  totalAmount Float
  serviceType String? // Label e.g. "Full Valet", "Service Wash"

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDITS
// Account manager quality audits — visible in customer portal
// ─────────────────────────────────────────────────────────────────────────────

model Audit {
  id                  String      @id @default(cuid())
  siteId              String
  site                Site        @relation(fields: [siteId], references: [id])
  accountManagerUserId String
  accountManager      User        @relation(fields: [accountManagerUserId], references: [id])
  visitDate           DateTime
  overallScore        Float?      // e.g. 0.0 to 100.0
  status              AuditStatus @default(DRAFT)
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  checklistItems AuditChecklistItem[]
  weeklyReviews  WeeklyReviewAudit[]

  @@index([siteId])
  @@index([accountManagerUserId])
}

enum AuditStatus {
  DRAFT     // Being filled in
  PUBLISHED // Visible to customer
}

model AuditChecklistItem {
  id          String        @id @default(cuid())
  auditId     String
  audit       Audit         @relation(fields: [auditId], references: [id])
  category    AuditCategory
  description String
  passed      Boolean
  note        String?
  photoUrl    String?

  @@index([auditId])
}

enum AuditCategory {
  SHOWROOM   // Showroom vehicles
  FORECOURT  // Used forecourt vehicles
  STANDARDS  // General standards (equipment, PPE, chemicals)
  FACILITIES // Site facilities (office, toilets)
}

// ─────────────────────────────────────────────────────────────────────────────
// WEEKLY REVIEWS
// Auto-generated Monday morning; emailed to head of business
// ─────────────────────────────────────────────────────────────────────────────

model WeeklyReview {
  id           String   @id @default(cuid())
  siteId       String
  site         Site     @relation(fields: [siteId], references: [id])
  weekStarting DateTime
  generatedAt  DateTime @default(now())

  totalJobsCompleted  Int
  totalCostExVat      Float
  complaintsRaised    Int   @default(0)
  complaintsRectified Int   @default(0)
  emailSentAt         DateTime?

  audits WeeklyReviewAudit[]

  @@unique([siteId, weekStarting])
  @@index([siteId])
}

model WeeklyReviewAudit {
  id             String       @id @default(cuid())
  weeklyReviewId String
  weeklyReview   WeeklyReview @relation(fields: [weeklyReviewId], references: [id])
  auditId        String
  audit          Audit        @relation(fields: [auditId], references: [id])

  @@index([weeklyReviewId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCOUNT MANAGER MESSAGES
// Direct messaging between customer and their account manager via the portal
// ─────────────────────────────────────────────────────────────────────────────

model AccountManagerMessage {
  id         String   @id @default(cuid())
  fromUserId String
  from       User     @relation("MessageFrom", fields: [fromUserId], references: [id])
  toUserId   String
  to         User     @relation("MessageTo", fields: [toUserId], references: [id])
  siteId     String
  message    String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([fromUserId])
  @@index([toUserId])
  @@index([siteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// HOLIDAY / LEAVE (unchanged)
// ─────────────────────────────────────────────────────────────────────────────

model HolidayRequest {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    HolidayStatus @default(PENDING)
  adminNote String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

enum HolidayStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveAllowance {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])
  year      Int
  totalDays Int    @default(28)
  usedDays  Float  @default(0)
}

// ─────────────────────────────────────────────────────────────────────────────
// LEGACY INVOICE (kept for data migration safety, to be removed post-migration)
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  organisationId String
  organisation   Organisation  @relation(fields: [organisationId], references: [id])
  siteId         String?
  periodStart    DateTime
  periodEnd      DateTime
  status         InvoiceStatus @default(DRAFT)
  lineItems      Json
  totalAmount    Float
  currency       String        @default("GBP")
  issuedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([organisationId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}
