  templateId     String
  template       RateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  serviceTypeName String      // matches ValetTypeTemplate.name
  basePricePence  Int
  baseAllocMins   Int         @default(60)
  pctSmall        Int         @default(-10)
  pctMedium       Int         @default(0)
  pctLarge        Int         @default(20)
  pctXL           Int         @default(35)
  pctVan          Int         @default(50)

  @@unique([templateId, serviceTypeName])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALERSHIP CONTACT LOG
// CRM-style notes: date, who was spoken to, what it regards, what was agreed
// Accessible by super_admin and management roles
// ─────────────────────────────────────────────────────────────────────────────

model DealershipNote {
  id           String   @id @default(cuid())
  dealershipId String
  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  contactDate  DateTime  // Date of the contact/conversation
  contactName  String    // Who was spoken to (e.g. "John Smith — Head of Business")
  regards      String    // Subject / what it regards
  agreed       String    @db.Text // What was agreed / outcome
  followUpDate DateTime? // Optional follow-up date

  createdByUserId String?
  createdBy        User?   @relation("DealershipNoteCreatedBy", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealershipId])
  @@index([contactDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALERSHIP REQUESTS
// Manager submits a new customer request; ops approves before it goes live
// ─────────────────────────────────────────────────────────────────────────────

enum DealershipRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DealershipRequest {
  id             String                  @id @default(cuid())
  organisationId String
  organisation   Organisation            @relation(fields: [organisationId], references: [id])

  // Basic details the manager fills in
  name           String
  address        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?                 @db.Text

  status         DealershipRequestStatus @default(PENDING)
  rejectionNote  String?                 // ops note if rejected

  // The live dealership created on approval (null until approved)
  dealershipId   String?                 @unique

  requestedById  String?
  requestedBy    User?                   @relation("DealershipRequestedBy", fields: [requestedById], references: [id])
  reviewedById   String?
  reviewedBy     User?                   @relation("DealershipReviewedBy", fields: [reviewedById], references: [id])

  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([organisationId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// VALETER ACCIDENT RECORDS
// Each accident: vehicle damaged, £1000 excess per vehicle, weekly deduction
// ─────────────────────────────────────────────────────────────────────────────

model ValeterAccident {
  id           String   @id @default(cuid())
  valeterId    String
  valeter      User     @relation("ValeterAccidents", fields: [valeterId], references: [id])

  incidentDate DateTime
  vehicleReg   String
  description  String   @db.Text
  excessAmount Float    @default(1000) // £1000 per vehicle
  weeklyDeduction Float? // agreed weekly deduction amount (£)
  totalDeducted   Float  @default(0)   // running total deducted so far
  settled         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([valeterId])
  @@index([incidentDate])
}

// ─── Smart Broadcast Feedback Replies ────────────────────────────────────────
// Tracks replies to pulse/feedback broadcast templates
// reply: "great" | "amazing" | "catchup"

model BroadcastFeedbackReply {
  id             String   @id @default(cuid())
  organisationId String
  messageId      String   // The original Message id sent to this user
  fromUserId     String
  fromUser       User     @relation("FeedbackReplies", fields: [fromUserId], references: [id])
  reply          String   // "great" | "amazing" | "catchup"
  siteId         String?
  createdAt      DateTime @default(now())

  @@index([organisationId])
  @@index([fromUserId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CSI SUPPORT SERVICES
// ─────────────────────────────────────────────────────────────────────────────

model SupportService {
  id             String                   @id @default(cuid())
  organisationId String
  organisation   Organisation             @relation(fields: [organisationId], references: [id])
  name           String
  group          String
  description    String?
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  bookings       SupportServiceBooking[]

  @@index([organisationId])
}

model SupportServiceBooking {
  id             String         @id @default(cuid())
  organisationId String
  organisation   Organisation   @relation(fields: [organisationId], references: [id])
  serviceId      String
  service        SupportService @relation(fields: [serviceId], references: [id])
  siteId         String
  site           Site           @relation(fields: [siteId], references: [id])
  scheduledDate  DateTime
  notes          String?
  contactName    String?
  status         String         @default("REQUESTED")
  createdAt      DateTime       @default(now())
  createdById    String?
  createdBy      User?          @relation(fields: [createdById], references: [id])

  @@index([organisationId])
  @@index([siteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORG VEHICLE SIZE CONFIG
// One row per org per vehicle size. LARGE is the baseline — its basePricePence
// and baseAllocMins are the reference point. Other sizes carry deltaPricePence
// and deltaMins relative to LARGE (negative = cheaper/faster).
// Defaults: SMALL(-5m/-£5), MEDIUM(-5m/-£5? no — per spec: MEDIUM is -5m/-£5
//   from LARGE, SMALL is -5m from MEDIUM = -10m/-£10 from LARGE, XL+5m/+£5,
//   VAN+5m/+£5 from LARGE).
// ─────────────────────────────────────────────────────────────────────────────
model OrgVehicleSizeConfig {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  size           VehicleSize

  // LARGE only: base price and base allocation time
  basePricePence Int?  // e.g. 2000 = £20.00
  baseAllocMins  Int?  // e.g. 60

  // Delta relative to LARGE (positive = more, negative = less)
  deltaPricePence Int @default(0)  // e.g. -500 = -£5, +500 = +£5
  deltaMins       Int @default(0)  // e.g. -5 = 5 min less, +5 = 5 min more

  // Display label override (e.g. "Small Hatchback")
  label String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, size])
  @@index([organisationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VALETER DEDUCTIONS
// Uniform costs, equipment charges, etc. deducted over multiple weeks.
// Ops team fills these in; they feed into the weekly payroll summary.
// ─────────────────────────────────────────────────────────────────────────────

model ValeterDeduction {
  id           String   @id @default(cuid())
  valeterId    String
  valeter      User     @relation("ValeterDeductions", fields: [valeterId], references: [id])

  description  String               // e.g. "Summer uniform (2 sets)"
  totalAmount  Float                // full cost to recover (£)
  weeklyAmount Float                // how much to deduct per week (£)
  totalDeducted Float  @default(0)  // running total deducted so far (£)
  settled      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([valeterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BANK DETAILS CHANGE REQUESTS
// Account manager raises a change request; £25 admin fee auto-deducted that
// week. Photo evidence uploaded. Record kept permanently on the valeter card.
// ─────────────────────────────────────────────────────────────────────────────

model BankChangeRequest {
  id           String   @id @default(cuid())
  valeterId    String
  valeter      User     @relation("ValeterBankChanges", fields: [valeterId], references: [id])

  // New bank details being requested
  newSortCode        String
  newAccountNumber   String
  newAccountName     String
  newBankReference   String?

  // Photo evidence (URL/key stored here — uploaded by account manager)
  evidenceUrl        String?

  // £25 admin fee — charged immediately on creation, pulled into that week's pay
  feeAmount          Float   @default(25)
  feeDeducted        Boolean @default(false)  // flips to true once processed in payroll
  weekDeducted       String? // ISO week-start date the £25 was deducted (e.g. "2026-07-07")

  // Status lifecycle: PENDING → APPROVED (bank details updated) or REJECTED
  status             BankChangeStatus @default(PENDING)
  notes              String?          // ops notes on approval/rejection

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([valeterId])
  @@index([status])
}

enum BankChangeStatus {
  VALETER_REQUESTED  // valeter submitted via their app — awaiting account manager review
  PENDING            // account manager approved — ops can now apply the change
  APPROVED           // ops applied the new bank details
  REJECTED           // rejected at any stage
}

// ─── Paint Protection Products ───────────────────────────────────────────────
// Configured by ops/super-admin in Settings > Paint Protection.
// Customer booking form pulls this list to replace the old hardcoded PAINT_TIERS.

model PaintProtectionProduct {
  id              String   @id @default(cuid())
  name                  String                         // e.g. "Essential", "Ceramic Pro"
  description           String?                        // short marketing line shown on booking card
  detailedDescription   String?                        // full detail shown via info icon
  durationMonths        Int                            // guarantee length in months (0 = no guarantee)
  guaranteeNote   String?                        // e.g. "Transferable to new owner"
  priceGbp        Float                          // customer-facing price
  applicationMins Int      @default(0)           // extra time added to booking slot
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  popular         Boolean  @default(false)       // highlights "Most Popular" badge

  // Bookings that used this product
  bookings        Booking[] @relation("BookingPaintProtection")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─── Day Rate Roles ───────────────────────────────────────────────────────────

/// Platform or org-level staff role types for day rate billing
model DayRateRole {
  id             String   @id @default(cuid())
  organisationId String?  // null = platform default; set = org-specific custom
  name           String
  description    String?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  dealershipDayRates DealershipDayRate[]
  operatives         DealershipOperative[]

  @@unique([organisationId, name])
  @@index([organisationId])
}

/// Day rate charged to a dealership for a staff role (9-hour day)
model DealershipDayRate {
  id           String      @id @default(cuid())
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  roleId       String
  role         DayRateRole @relation(fields: [roleId], references: [id])
  ratePence    Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([dealershipId, roleId])
  @@index([dealershipId])
}

// ─── Standing Charges ─────────────────────────────────────────────────────────

/// Recurring extra work items set by ops per valeter.
/// Auto-populated onto every timesheet as TimesheetExtraLine rows.
model ValeterStandingCharge {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description    String   // e.g. "Workshop Cleaning", "Driver duties"
  ratePence      Int      // weekly charge in pence
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

/// Extra work line on a timesheet — auto-seeded from ValeterStandingCharge.
/// Ops can also add one-off lines manually.
model TimesheetExtraLine {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  description String
  ratePence   Int
  isRecurring Boolean   @default(true)  // true = came from standing charge
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([timesheetId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VALETER EXPENSES / RECEIPT SUBMISSIONS
// ─────────────────────────────────────────────────────────────────────────────

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Receipt submitted by a valeter for reimbursement — paid with weekly wages.
model ValeterExpense {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId      String?
  site        Site?         @relation(fields: [siteId], references: [id])

  description String        // What the receipt is for
  amountPence Int           // Amount requested in pence

  receiptFileUrl String?    // URL to uploaded receipt image/PDF

  /// Which week's wages this should be paid with (week starting Monday)
  weekStarting DateTime

  status      ExpenseStatus @default(PENDING)
  reviewedByUserId String?
  reviewedAt  DateTime?
  reviewNote  String?       // Rejection reason if rejected

  /// Set when this expense is bundled into a timesheet payroll lock
  timesheetId          String?
  timesheet            Timesheet? @relation(fields: [timesheetId], references: [id])

  /// Xero nominal code used when pushing this expense to Xero (org-level setting)
  xeroNominalCodeId    String?
  xeroNominalCode      XeroExpenseNominalCode? @relation(fields: [xeroNominalCodeId], references: [id])

  /// Set once pushed to Xero
  xeroPushedAt         DateTime?
  xeroInvoiceId        String?   // Xero Invoice GUID

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([siteId])
  @@index([weekStarting])
  @@index([status])
  @@index([timesheetId])
}

// ─────────────────────────────────────────────────────────────────────────────
// XERO EXPENSE NOMINAL CODES
// Org-level mapping of expense categories to Xero account codes.
// One "Consumables" code covers all valeter receipt reimbursements.
// ─────────────────────────────────────────────────────────────────────────────

model XeroExpenseNominalCode {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  name           String       // e.g. "Consumables"
  xeroAccountCode String      // e.g. "7400"
  xeroAccountName String?     // e.g. "Consumables" (synced from Xero)
  taxType        String       @default("INPUT2")  // INPUT2 = 20% VAT reclaimable
  isDefault      Boolean      @default(false)    // one default per org

  expenses              ValeterExpense[]
  serviceChargeRequests ServiceChargeRequest[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organisationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALERSHIP OPERATIVES & WEEKLY TASKS
// Replaces the flat DealershipDayRate with a richer staffing plan per site.
// ─────────────────────────────────────────────────────────────────────────────

/// One operative position allocated to a dealership site.
/// e.g. "2× Valeting Operative in Sales dept, 8h/day @ £140/day each"
model DealershipOperative {
  id           String      @id @default(cuid())
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  roleId       String
  role         DayRateRole @relation(fields: [roleId], references: [id])

  /// Department at this site (e.g. Sales, Service, Bodyshop). Nullable = all depts.
  departmentName String?

  /// Number of operatives of this role/dept combination
  quantity     Int         @default(1)

  /// Allocated working hours per operative per day (used to measure vs booked work)
  allocatedHoursPerDay Float @default(8)

  /// Day rate charged to dealer per operative (pence)
  dayRatePence Int

  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([dealershipId])
}

/// Recurring additional weekly work required at a dealership.
/// e.g. "Workshop Cleaning — 2h/week @ £50"
model DealershipWeeklyTask {
  id           String     @id @default(cuid())
  dealershipId String
  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  description  String     // e.g. "Workshop Cleaning"

  /// Allocated hours per week for this task
  allocatedHoursPerWeek Float @default(1)

  /// Weekly charge to dealer (pence)
  weeklyRatePence Int

  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([dealershipId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE WEEK SUBMISSION
// One record per site per week — tracks the bundle sent to the dealer for sign-off.
// Created when ops hits "Send to Dealer". Dealer approves or raises a review note.
// Auto-approved after 4 hours if no response.
// ─────────────────────────────────────────────────────────────────────────────

enum SiteSubmissionStatus {
  PENDING_SEND      // all valeters approved, not yet sent
  SENT              // sent to dealer, awaiting response
  DEALER_ACCEPTED   // dealer signed off
  DEALER_DISPUTED   // dealer raised a query
  AUTO_ACCEPTED     // auto-approved after 4h
}

model SiteWeekSubmission {
  id           String                @id @default(cuid())
  siteId       String
  site         Site                  @relation(fields: [siteId], references: [id])
  weekStarting DateTime

  status       SiteSubmissionStatus  @default(PENDING_SEND)

  // Timestamps
  sentAt             DateTime?   // when ops hit Send to Dealer
  dealerRespondedAt  DateTime?
  autoAcceptedAt     DateTime?

  // Dealer response
  dealerDisputeNote  String?     // filled when DEALER_DISPUTED

  // Who sent it
  sentByUserId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, weekStarting])
  @@index([siteId])
  @@index([weekStarting])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROSPECT VALETERS
// Pre-registration pipeline — capture name, email, phone before they become
// a full User. Can be converted to a User account once onboarded.
// ─────────────────────────────────────────────────────────────────────────────

enum ProspectStatus {
  NEW         // just added
  CONTACTED   // ops/manager has been in touch
  INTERVIEWED // met or spoken in depth
  OFFERED     // offer made
  ONBOARDED   // converted to full User account
  DECLINED    // not proceeding
}

model ProspectValeter {
  id             String          @id @default(cuid())
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id])

  // Core contact
  firstName   String
  lastName    String
  email       String?
  phone       String?           // mobile
  town        String?           // town or area they are based in

  // Experience & suitability
  experience        String?   @db.Text // current / previous valeting experience
  ukLicence         Boolean?           // holds UK driving licence
  drives            Boolean?           // willing/able to drive on site
  position          String?           // position they are interested in e.g. "Valeter", "Team Leader"
  payRequirementMin Int?              // minimum pay expectation (pence per day)
  payRequirementMax Int?              // maximum pay expectation (pence per day)

  // Pipeline
  notes       String?           @db.Text // general notes
  status      ProspectStatus    @default(NEW)
  source      String?           // how they came to us e.g. "Area broadcast", "Referral", "Walk-in"
  siteId      String?           // preferred / intended site
  site        Site?             @relation(fields: [siteId], references: [id])

  employmentHistory String?   @db.Text // structured free-text of past employment

  addedByUserId     String?     // who added the prospect
  convertedToUserId String?     // set when onboarded → User

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  broadcastRecipients ProspectBroadcastRecipient[]

  @@index([organisationId])
  @@index([status])
  @@index([town])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROSPECT BROADCAST
// Group SMS/email blast to prospects in a given area when recruiting.
// Recipients are drawn from ProspectValeter records matching town/area filter.
// ─────────────────────────────────────────────────────────────────────────────

model ProspectBroadcast {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  subject        String                        // e.g. "Valeting positions available in Swindon"
  message        String       @db.Text         // the message body
  areaFilter     String?                       // town/area filter used to select recipients
  statusFilter   String?                       // prospect status filter used (e.g. "NEW,CONTACTED")
  recipientCount Int          @default(0)      // how many prospects received it

  sentByUserId   String
  sentBy         User         @relation("ProspectBroadcastSentBy", fields: [sentByUserId], references: [id])
  sentAt         DateTime     @default(now())

  recipients ProspectBroadcastRecipient[]

  @@index([organisationId])
  @@index([sentAt])
}

model ProspectBroadcastRecipient {
  id          String              @id @default(cuid())
  broadcastId String
  broadcast   ProspectBroadcast   @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  prospectId  String
  prospect    ProspectValeter     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  sentAt      DateTime            @default(now())

  @@unique([broadcastId, prospectId])
  @@index([prospectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE EQUIPMENT
// Equipment registered on-site at a dealership.
// Each item is tracked with delivery date, photo, responsible person,
// and a monthly stock-check record.
// ─────────────────────────────────────────────────────────────────────────────

model SiteEquipment {
  id           String   @id @default(cuid())
  siteId       String
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name         String            // e.g. "Karcher Pressure Washer"
  description  String?           // make/model, serial number etc.
  deliveredAt  DateTime?         // when delivered on site
  photoUrl     String?           // equipment photo
  responsibleUserId String?      // valeter / team leader responsible
  responsibleUser   User?        @relation("EquipmentResponsible", fields: [responsibleUserId], references: [id])

  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  stockChecks  EquipmentStockCheck[]
  auditItems   EquipmentAuditItem[]

  @@index([siteId])
}

/// Monthly stock check for a single piece of equipment.
model EquipmentStockCheck {
  id              String         @id @default(cuid())
  equipmentId     String
  equipment       SiteEquipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  checkedByUserId String?
  checkedBy       User?          @relation("StockCheckBy", fields: [checkedByUserId], references: [id])

  checkedAt   DateTime           @default(now())
  present     Boolean            // is the item on site?
  condition   String?            // Good / Fair / Poor
  notes       String?
  photoUrl    String?

  @@index([equipmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT SAFETY AUDITS
// Team leader submits a weekly Monday safety audit covering all site equipment.
// Each audit has one item-level result per piece of equipment.
// ─────────────────────────────────────────────────────────────────────────────

enum AuditResult {
  PASS
  ADVISORY   // minor issue, note added
  FAIL       // out of service / safety concern
}

model EquipmentAudit {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  conductedByUserId String?
  conductedBy       User?   @relation("AuditConductedBy", fields: [conductedByUserId], references: [id])

  auditDate   DateTime         // the Monday the audit was for
  submittedAt DateTime         @default(now())
  overallPass Boolean          @default(true)  // false if any FAIL items
  notes       String?          // overall audit notes

  items       EquipmentAuditItem[]

  @@index([siteId])
  @@index([auditDate])
}

model EquipmentAuditItem {
  id           String          @id @default(cuid())
  auditId      String
  audit        EquipmentAudit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  equipmentId  String
  equipment    SiteEquipment   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  result       AuditResult     @default(PASS)
  notes        String?
  photoUrl     String?

  @@index([auditId])
  @@index([equipmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VEHICLE INSPECTION TEMPLATES
// Org-level templates (e.g. "PDI — New Vehicle", "Used Transfer Inspection").
// Each template has an ordered list of check items.
// Sites opt in to templates and can override individual checks.
// ─────────────────────────────────────────────────────────────────────────────

model InspectionTemplate {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  name        String              // e.g. "PDI — New Vehicle"
  description String?             // e.g. "Checklist for vehicles arriving on transporter"
  type        InspectionType      // PDI | USED_TRANSFER | CUSTOM
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkItems    InspectionCheckItem[]
  siteTemplates SiteInspectionTemplate[]

  @@index([organisationId])
}

enum InspectionType {
  PDI            // New vehicle arriving from manufacturer/transporter
  USED_TRANSFER  // Used vehicle arriving from another dealership/auction
  CUSTOM         // Anything else
}

model InspectionCheckItem {
  id         String             @id @default(cuid())
  templateId String
  template   InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  label       String              // e.g. "Spare Key Present"
  description String?             // optional hint for the valeter
  category    String              // e.g. "Accessories", "Documents", "Exterior", "Interior"
  isRequired  Boolean @default(true)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteOverrides SiteInspectionCheckOverride[]

  @@index([templateId])
}

/// Which inspection templates are active at a given site.
model SiteInspectionTemplate {
  id         String             @id @default(cuid())
  siteId     String
  site       Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  templateId String
  template   InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkOverrides SiteInspectionCheckOverride[]

  @@unique([siteId, templateId])
  @@index([siteId])
}

enum InspectionCheckOverrideType {
  HIDDEN  // remove a default check for this site
  ADDED   // add a site-specific extra check
}

/// Per-site overrides to individual check items.
/// HIDDEN = default check suppressed at this site.
/// ADDED  = extra check added only at this site (checkItemId is null; label/category stored inline).
model SiteInspectionCheckOverride {
  id                     String                     @id @default(cuid())
  siteTemplateId         String
  siteTemplate           SiteInspectionTemplate     @relation(fields: [siteTemplateId], references: [id], onDelete: Cascade)

  overrideType           InspectionCheckOverrideType

  // For HIDDEN: reference to the default check being suppressed
  checkItemId            String?
  checkItem              InspectionCheckItem?       @relation(fields: [checkItemId], references: [id], onDelete: Cascade)

  // For ADDED: inline definition of the extra check
  label                  String?
  description            String?
  category               String?
  isRequired             Boolean @default(true)
  sortOrder              Int     @default(0)

  createdAt DateTime @default(now())

  @@index([siteTemplateId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RECURRING JOB TEMPLATES
// Account manager creates templates per site/dealership.
// Each day, the system generates one RecurringJobOccurrence per active template
// that is scheduled for that day.
// ─────────────────────────────────────────────────────────────────────────────

enum RecurringFrequency {
  DAILY         // every working day (Mon–Fri by default unless customDays set)
  SPECIFIC_DAYS // only on days in customDays e.g. ["MON","WED","FRI"]
  EVERY_OTHER_DAY
  WEEKLY        // same day each week
  FORTNIGHTLY
  MONTHLY       // same date each month (or 1st, last, etc.)
}

model RecurringJobTemplate {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])

  /// Human-readable name e.g. "Daily Showroom Walk", "Pitch Tyre Shine"
  name           String

  /// Longer description shown to the valeter on the job card
  description    String?

  frequency      RecurringFrequency @default(DAILY)

  /// For SPECIFIC_DAYS: JSON array of day names ["MON","TUE","WED","THU","FRI"]
  customDays     Json?   // string[]

  /// "Must be done by" local time HH:MM — used for overdue detection
  mustDoneByTime String  @default("17:00")

  /// Optional: assign to a specific valeter. If null, any valeter can claim.
  assignedToId   String?
  assignedTo     User?   @relation("RecurringJobAssignee", fields: [assignedToId], references: [id])

  isActive       Boolean @default(true)
  createdById    String
  createdBy      User    @relation("RecurringJobCreator", fields: [createdById], references: [id])

  /// Audit checklist questions — JSON array of strings
  /// e.g. ["Showroom floor clean?","Tyres shined?","Display cars wiped down?"]
  auditQuestions Json?   // string[]

  occurrences    RecurringJobOccurrence[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organisationId])
  @@index([siteId])
  @@index([isActive])
}

enum RecurringJobStatus {
  PENDING    // generated, not yet claimed
  CLAIMED    // valeter has accepted/started
  COMPLETED  // valeter signed off (with audit answers)
  MISSED     // deadline passed without completion
}

model RecurringJobOccurrence {
  id         String   @id @default(cuid())
  templateId String
  template   RecurringJobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  /// Date this occurrence is for (midnight UTC of that day)
  dueDate    DateTime

  status     RecurringJobStatus @default(PENDING)

  /// Valeter who claimed/completed this occurrence
  claimedById  String?
  claimedBy    User?   @relation("RecurringJobClaimer", fields: [claimedById], references: [id])

  claimedAt    DateTime?
  completedAt  DateTime?

  /// Photo evidence URL (uploaded by valeter)
  photoUrl     String?

  /// Free-text completion note from valeter
  completionNote String?

  auditAnswers   RecurringJobAuditAnswer[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateId, dueDate])
  @@index([templateId])
  @@index([dueDate])
  @@index([status])
}

/// One answer per audit question per occurrence
model RecurringJobAuditAnswer {
  id           String   @id @default(cuid())
  occurrenceId String
  occurrence   RecurringJobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  question     String   // copied from template.auditQuestions at time of completion
  answer       Boolean  // true = Yes / confirmed, false = No / issue flagged

  createdAt    DateTime @default(now())

  @@index([occurrenceId])
}
