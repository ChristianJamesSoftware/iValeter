generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANISATION
// ─────────────────────────────────────────────────────────────────────────────

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Profile
  logoUrl        String?
  billingAddress String?
  vatNumber      String?
  contactEmail   String?
  contactPhone   String?

  // Accounts department contact
  accountsContactName   String?
  accountsContactEmail  String?
  accountsContactPhone  String?

  // Payment terms
  paymentTermsDays  Int?     // e.g. 14, 30, 60 — net days
  paymentTermsNote  String?  // e.g. "Month end + 14 days"
  creditLimit       Float?   // optional credit limit (£)

  // Feature flags (defaults seeded from platform-level flags)
  featureInspection      Boolean @default(true)
  featurePhotography     Boolean @default(false)
  featureFreshScent      Boolean @default(true)
  featurePaintProtection Boolean @default(true)
  featureXero            Boolean @default(false)
  // Phase 1 feature flags
  featureGeofencing      Boolean @default(false)
  featureTimesheets      Boolean @default(false)
  featurePayroll         Boolean @default(false)
  featureCustomerPortal  Boolean @default(false)

  sites            Site[]
  dealerships      Dealership[]
  users            User[]
  invoices         Invoice[]
  customerInvoices CustomerInvoice[]
  payRuns          PayRun[]
  xeroConnection          XeroConnection?
  xeroExpenseNominalCodes XeroExpenseNominalCode[]
  serviceChargeRequests   ServiceChargeRequest[]
  supportServices         SupportService[]
  supportServiceBookings  SupportServiceBooking[]
  vehicleSizeConfigs      OrgVehicleSizeConfig[]
  dealershipRequests      DealershipRequest[]
  prospectValeters         ProspectValeter[]
  prospectBroadcasts       ProspectBroadcast[]
  inspectionTemplates      InspectionTemplate[]
  recurringJobTemplates    RecurringJobTemplate[]
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALERSHIP
// ─────────────────────────────────────────────────────────────────────────────

model Dealership {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  address        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?

  // Accounts department contact
  accountsContactName   String?
  accountsContactEmail  String?
  accountsContactPhone  String?

  // Payment terms
  paymentTermsDays  Int?     // e.g. 14, 30, 60 — net days
  paymentTermsNote  String?  // e.g. "Month end + 14 days"
  creditLimit       Float?   // optional credit limit (£)
  isActive             Boolean  @default(true)
  logoUrl              String?  // dealership brand logo (URL)
  xeroContactId        String?
  xeroContactName      String?
  specialInstructions  String?
  createdAt            DateTime @default(now())

  sites            Site[]
  dealershipAddOns DealershipAddOn[]
  notes            DealershipNote[]
  dayRates         DealershipDayRate[]
  operatives       DealershipOperative[]
  weeklyTasks      DealershipWeeklyTask[]

  @@index([organisationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE
// Extended: geofence, billing terms, account manager, customer contact
// ─────────────────────────────────────────────────────────────────────────────

model Site {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  address        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  dealershipId String?
  dealership   Dealership? @relation(fields: [dealershipId], references: [id])

  // Geofencing
  geofenceLat          Float?
  geofenceLng          Float?
  geofenceRadiusMetres Int?   @default(100)

  // Customer billing config
  billingCycle  BillingCycle @default(WEEKLY)
  paymentTerms  PaymentTerms @default(NET14)
  xeroContactId String?

  // Customer contact (receives timesheet approval + weekly review emails)
  customerContactName  String?
  customerContactEmail String?

  // Account manager from Total Valeting assigned to this site
  accountManagerUserId String?
  accountManager       User?   @relation("AccountManagerSites", fields: [accountManagerUserId], references: [id])

  departments             Department[]
  bookings                Booking[]
  users                   User[]
  clockEvents             ClockEvent[]
  timesheets              Timesheet[]
  customerInvoices        CustomerInvoice[]
  audits                  Audit[]
  weeklyReviews           WeeklyReview[]
  vehicleSizeRates        VehicleSizeRate[]
  supportServiceBookings  SupportServiceBooking[]
  expenses                 ValeterExpense[]
  serviceChargeRequests    ServiceChargeRequest[]
  siteWeekSubmissions      SiteWeekSubmission[]
  prospectValeters          ProspectValeter[]
  equipment                 SiteEquipment[]
  equipmentAudits           EquipmentAudit[]
  siteInspectionTemplates   SiteInspectionTemplate[]
  recurringJobTemplates     RecurringJobTemplate[]

  @@index([organisationId])
}

enum BillingCycle {
  WEEKLY
  MONTHLY
}

enum PaymentTerms {
  NET14
  MONTH_END
  MONTH_END_PLUS1
}

// ─────────────────────────────────────────────────────────────────────────────
// DEPARTMENT
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])
  name   String

  users        User[]        @relation("UserDepartment")
  bookings     Booking[]
  serviceTypes ServiceType[]

  @@index([siteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Extended: staffType (SITE/SSS), phone, NatWest Bankline fields
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  siteId         String?
  site           Site?        @relation(fields: [siteId], references: [id])
  departmentId   String?      // for dealership_user: their assigned department
  department     Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role
  staffType      StaffType    @default(SITE)
  skills         String[]
  avatarUrl      String?
  phone          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  // Valeting team fields
  mobile           String?
  payId            String? // auto-generated: XXXX.XXXX format
  dailyRate        Float?
  dailyDeductions  Float?
  startDate        DateTime?
  contractComplete Boolean   @default(false)

  // Schedule (set by head office)
  workingDays      String[]  // e.g. ["MON","TUE","WED","THU","FRI"]
  contractedHours  Float?    // daily contracted hours, e.g. 8.0
  saturdayHalfDay  Boolean   @default(false)
  dayHours         Json?     // e.g. {"MON":8,"TUE":8,"WED":8,"THU":8,"FRI":8,"SAT":4}
  shiftStartTime    String?   // e.g. "08:00" — contracted start (HH:mm)
  shiftEndTime      String?   // e.g. "17:00" — contracted finish used by auto clock-out sweep

  // Dealership team field
  jobTitle String?

  // Management team field (only for role = management)
  managementRole ManagementRole?

  // NatWest Bankline payroll fields
  bankSortCode      String?
  bankAccountNumber String?
  bankAccountName   String?
  bankReference     String?

  // Password reset
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  // Activity tracking
  lastLoginAt DateTime? // stamped on every successful login
  archivedAt  DateTime? // set when user is archived (soft-delete)

  assignedBookings     Booking[]          @relation("AssignedValeter")
  createdBookings      Booking[]          @relation("CreatedBy")
  dealershipNotes      DealershipNote[]   @relation("DealershipNoteCreatedBy")
  statusHistory        JobStatusHistory[]
  holidayRequests      HolidayRequest[]
  leaveAllowance       LeaveAllowance?
  clockEvents          ClockEvent[]
  timesheets           Timesheet[]
  payRunLines          PayRunLine[]
  contractorRates      ContractorRate[]
  auditsConducted      Audit[]
  complaintsRaised     Complaint[]        @relation("RaisedBy")
  complaintsRectified  Complaint[]        @relation("RectifiedBy")
  accountManagerSites  Site[]             @relation("AccountManagerSites")
  sentMessages         AccountManagerMessage[] @relation("MessageFrom")
  receivedMessages     AccountManagerMessage[] @relation("MessageTo")
  messagesSent         Message[]               @relation("MessageFrom")
  messagesReceived     Message[]               @relation("MessageTo")
  overtimeRequests       OvertimeRequest[]
  serviceChargeRequests  ServiceChargeRequest[] @relation("ServiceChargeRequests")
  accidents              ValeterAccident[]      @relation("ValeterAccidents")
  deductions           ValeterDeduction[]  @relation("ValeterDeductions")
  bankChangeRequests       BankChangeRequest[]  @relation("ValeterBankChanges")
  dealershipRequestsMade   DealershipRequest[]  @relation("DealershipRequestedBy")
  dealershipRequestsReviewed DealershipRequest[] @relation("DealershipReviewedBy")
  feedbackReplies         BroadcastFeedbackReply[] @relation("FeedbackReplies")
  supportServiceBookings  SupportServiceBooking[]
  standingCharges         ValeterStandingCharge[]
  expenses                 ValeterExpense[]
  equipmentResponsible     SiteEquipment[]        @relation("EquipmentResponsible")
  stockChecksBy            EquipmentStockCheck[]  @relation("StockCheckBy")
  auditsLed                EquipmentAudit[]       @relation("AuditConductedBy")
  recurringJobsAssigned    RecurringJobTemplate[] @relation("RecurringJobAssignee")
  recurringJobsCreated     RecurringJobTemplate[] @relation("RecurringJobCreator")
  recurringJobsClaimed     RecurringJobOccurrence[] @relation("RecurringJobClaimer")
  timesheetDeductionsAdded TimesheetDeduction[]   @relation("TimesheetDeductionAddedBy")
  prospectBroadcastsSent   ProspectBroadcast[]    @relation("ProspectBroadcastSentBy")

  @@index([organisationId])
  @@index([siteId])
}

enum Role {
  super_admin
  org_admin
  dealership_user
  valeter
  management
}

enum ManagementRole {
  ADMINISTRATION
  ACCOUNTANT
  ACCOUNT_MANAGER
  COO
  CEO
}

enum StaffType {
  SITE // Fixed to one site
  SSS  // Site Support Staff — mobile, covers any site
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE TYPE
// Extended: description, category, chargeRate
// ─────────────────────────────────────────────────────────────────────────────

model ServiceType {
  id           String          @id @default(cuid())
  departmentId String
  department   Department      @relation(fields: [departmentId], references: [id])
  name         String
  description  String?
  category     ServiceCategory @default(VALET)
  durationMins Int
  chargeRate   Float?
  isActive     Boolean         @default(true)
  nominalCode  String? // Xero nominal/account code for invoicing

  bookings         Booking[]
  vehicleSizeRates VehicleSizeRate[]

  @@index([departmentId])
}

enum ServiceCategory {
  VALET    // Service Wash, Full Valet, New Car Prep, Paint Protection
  PAINT    // Machine Polish, Special Polish
  CLEANING // Showroom Clean, Office Clean, Toilet Clean
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKING
// Extended: priorityLevel, keyNumber, vehicleLocation, notification fields
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id             String      @id @default(cuid())
  organisationId String
  siteId         String
  site           Site        @relation(fields: [siteId], references: [id])
  departmentId   String
  department     Department  @relation(fields: [departmentId], references: [id])
  serviceTypeId  String
  serviceType    ServiceType @relation(fields: [serviceTypeId], references: [id])

  vehicleReg      String
  vehicleMake     String?
  vehicleModel    String?
  vehicleColour   String?
  customerName    String
  keyNumber       String?
  vehicleLocation String?

  status        BookingStatus @default(PENDING)
  isPriority    Boolean       @default(false)
  priorityLevel PriorityLevel @default(STANDARD)
  readyByTime   DateTime

  // Phase 2 add-ons
  includeInspection      Boolean @default(false)
  inspectionComplete     Boolean @default(false)
  includeFreshScent      Boolean @default(false)
  paintProtectionTier    String? // legacy — kept for backwards compat, new bookings use paintProtectionProductId
  paintProtectionProductId String?  // FK → PaintProtectionProduct
  paintProtectionProduct   PaintProtectionProduct? @relation("BookingPaintProtection", fields: [paintProtectionProductId], references: [id])
  freshScentConfirmed    Boolean @default(false)
  paintProtectionApplied Boolean @default(false)
  photographyPackage     String? // null | "standard" | "premium" | "full"

  assignedToId String?
  assignedTo   User?   @relation("AssignedValeter", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User    @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Completion notification
  notifyEmail                String?
  notifyPhone                String?
  completionNotificationSent Boolean @default(false)

  // Do Not Clean flag — customer has requested vehicle is NOT cleaned
  doNotClean         Boolean @default(false)

  // Budget limit — alert booker if job cost exceeds this
  budgetLimit Float? // £ amount, set at booking time

  // Vehicle parking pin — valeter drops GPS pin when parking completed car
  parkingLat        Float?
  parkingLng        Float?
  parkingConfirmedAt DateTime?

  // Customer review note
  customerReviewNote String?

  // Dealer quality score (1–5 stars) and feedback left on the job card
  qualityScore Int?    // 1-5
  qualityNote  String?

  // Vehicle sizing for piece-work pricing and time allocation
  vehicleSize          VehicleSize?
  resolvedPricePence   Int?  // calculated from OrgVehicleSizeConfig at booking time
  resolvedDurationMins Int?  // calculated from OrgVehicleSizeConfig at booking time

  // Roll tracking — incremented each time an account manager reschedules an overdue job
  rollCount    Int       @default(0)
  lastRolledAt DateTime?

  statusHistory         JobStatusHistory[]
  photos                JobPhoto[]
  complaints            Complaint[]
  serviceChargeRequests ServiceChargeRequest[]

  @@index([organisationId])
  @@index([siteId])
  @@index([departmentId])
  @@index([assignedToId])
  @@index([status])
  @@index([vehicleReg])
  @@index([priorityLevel])
}

enum BookingStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  QC_CHECK
  COMPLETED
  CANCELLED
}

enum PriorityLevel {
  STANDARD
  PRIORITY
  URGENT
}

enum VehicleSize {
  SMALL
  MEDIUM
  LARGE
  XL
  VAN
}

model JobStatusHistory {
  id         String         @id @default(cuid())
  bookingId  String
  booking    Booking        @relation(fields: [bookingId], references: [id])
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  fromStatus BookingStatus?
  toStatus   BookingStatus
  note       String?
  createdAt  DateTime       @default(now())

  @@index([bookingId])
}

model JobPhoto {
  id        String    @id @default(cuid())
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id])
  url       String
  type      PhotoType @default(AFTER) // BEFORE = pre-valet/damage, AFTER = post-valet/finished
  stage     String    @default("pre_valet") // "pre_valet" | "post_valet" | "photography"
  label     String?   // human readable e.g. "Front of vehicle"
  createdAt DateTime  @default(now())

  @@index([bookingId])
}

enum PhotoType {
  BEFORE
  AFTER
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPLAINTS
// ─────────────────────────────────────────────────────────────────────────────

model Complaint {
  id             String          @id @default(cuid())
  bookingId      String
  booking        Booking         @relation(fields: [bookingId], references: [id])
  raisedByUserId String
  raisedBy       User            @relation("RaisedBy", fields: [raisedByUserId], references: [id])
  note           String
  status         ComplaintStatus @default(OPEN)

  rectifiedByUserId String?
  rectifiedBy       User?     @relation("RectifiedBy", fields: [rectifiedByUserId], references: [id])
  rectifiedNote     String?
  rectifiedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RECTIFIED
  CLOSED
}

// ─────────────────────────────────────────────────────────────────────────────
// CLOCK EVENTS
// ─────────────────────────────────────────────────────────────────────────────

model ClockEvent {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  siteId            String
  site              Site           @relation(fields: [siteId], references: [id])
  type              ClockEventType
  timestamp         DateTime
  lat               Float?
  lng               Float?
  geofenceTriggered Boolean        @default(false)
  createdAt         DateTime       @default(now())

  @@index([userId])
  @@index([siteId])
  @@index([timestamp])
}

enum ClockEventType {
  CLOCK_IN
  CLOCK_OUT
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTRACTOR RATES
// ─────────────────────────────────────────────────────────────────────────────

model ContractorRate {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  hourlyRate    Float
  overtimeRate  Float
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TIMESHEETS
// ─────────────────────────────────────────────────────────────────────────────

model Timesheet {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  siteId       String
  site         Site            @relation(fields: [siteId], references: [id])
  weekStarting DateTime
  weekEnding   DateTime

  totalRegularHours  Float @default(0)
  totalOvertimeHours Float @default(0)

  status           TimesheetStatus @default(DRAFT)
  approvedByUserId String?
  approvedAt       DateTime?

  saApprovedByUserId String?
  saApprovedAt       DateTime?

  sentToCustomerAt    DateTime?
  customerAccepted    Boolean   @default(false)
  customerAcceptedAt  DateTime?
  autoAccepted        Boolean   @default(false)
  customerDisputeNote String?
  lateConfirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines      TimesheetLine[]
  extraLines TimesheetExtraLine[]
  deductions TimesheetDeduction[]
  expenses   ValeterExpense[]
  payRunLine PayRunLine?

  @@unique([userId, weekStarting])
  @@index([userId])
  @@index([siteId])
  @@index([status])
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  DISPUTED
  LOCKED
  SA_APPROVED
}

model TimesheetLine {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])
  date        DateTime

  clockInTime  DateTime?
  clockOutTime DateTime?
  breakMins    Int       @default(60)

  regularHours       Float  @default(0)
  overtimeHours      Float  @default(0)
  overtimeRequestId  String? // links back to the approved OvertimeRequest
  note               String?

  @@index([timesheetId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAY RUNS
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// TIMESHEET DEDUCTIONS
// Applied post-customer-approval: daily deductions, accident excess, uniform, etc.
// finalPay = grossPay - sum(deductions)
// ─────────────────────────────────────────────────────────────────────────────

model TimesheetDeduction {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  type        DeductionType
  description String        // human-readable label e.g. "Uniform — week 1 of 4"
  amountPence Int           // deduction amount in pence (positive = deduction from pay)

  // Optional link back to source records
  accidentId         String? // ValeterAccident.id if type == ACCIDENT
  valeterDeductionId String? // ValeterDeduction.id if type == STANDING
  expenseId          String? // ValeterExpense.id if type == EXPENSE

  addedByUserId String
  addedBy       User   @relation("TimesheetDeductionAddedBy", fields: [addedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([timesheetId])
}

enum DeductionType {
  DAILY      // agreed daily deduction (e.g. £X/day for X days)
  ACCIDENT   // accident excess recovery
  UNIFORM    // uniform/equipment cost recovery
  STANDING   // recurring weekly deduction (from ValeterDeduction)
  EXPENSE    // approved valeter receipt reimbursement (adds to net pay)
  OTHER      // ad-hoc ops-entered deduction
}

model PayRun {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  weekStarting   DateTime
  weekEnding     DateTime
  status         PayRunStatus @default(DRAFT)
  exportedAt     DateTime?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines PayRunLine[]

  @@unique([organisationId, weekStarting])
  @@index([organisationId])
}

enum PayRunStatus {
  DRAFT
  APPROVED
  EXPORTED
  PAID
}

model PayRunLine {
  id          String    @id @default(cuid())
  payRunId    String
  payRun      PayRun    @relation(fields: [payRunId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  timesheetId String    @unique
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])

  regularHours  Float
  overtimeHours Float
  hourlyRate    Float
  overtimeRate  Float
  totalAmount   Float

  bankSortCode      String?
  bankAccountNumber String?
  bankAccountName   String?
  bankReference     String?

  @@index([payRunId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMER INVOICES
// ─────────────────────────────────────────────────────────────────────────────

model CustomerInvoice {
  id             String                @id @default(cuid())
  organisationId String
  organisation   Organisation          @relation(fields: [organisationId], references: [id])
  siteId         String
  site           Site                  @relation(fields: [siteId], references: [id])
  periodStart    DateTime
  periodEnd      DateTime
  billingCycle   BillingCycle
  paymentTerms   PaymentTerms
  dueDate        DateTime
  status         CustomerInvoiceStatus @default(DRAFT)
  totalAmount    Float
  currency       String                @default("GBP")

  xeroInvoiceId     String?
  xeroInvoiceNumber String?
  xeroSyncedAt      DateTime?

  issuedAt  DateTime?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lineItems CustomerInvoiceLineItem[]

  @@index([organisationId])
  @@index([siteId])
  @@index([status])
}

enum CustomerInvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  DISPUTED
  PAID
  OVERDUE
}

model CustomerInvoiceLineItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     CustomerInvoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Float
  unitAmount  Float
  totalAmount Float
  serviceType String?

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDITS
// ─────────────────────────────────────────────────────────────────────────────

model Audit {
  id                   String      @id @default(cuid())
  siteId               String
  site                 Site        @relation(fields: [siteId], references: [id])
  accountManagerUserId String
  accountManager       User        @relation(fields: [accountManagerUserId], references: [id])
  visitDate            DateTime
  overallScore         Float?
  status               AuditStatus @default(DRAFT)
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  checklistItems AuditChecklistItem[]
  weeklyReviews  WeeklyReviewAudit[]

  @@index([siteId])
  @@index([accountManagerUserId])
}

enum AuditStatus {
  DRAFT
  PUBLISHED
}

model AuditChecklistItem {
  id          String        @id @default(cuid())
  auditId     String
  audit       Audit         @relation(fields: [auditId], references: [id])
  category    AuditCategory
  description String
  passed      Boolean
  note        String?
  photoUrl    String?

  @@index([auditId])
}

enum AuditCategory {
  SHOWROOM
  FORECOURT
  STANDARDS
  FACILITIES
}

// ─────────────────────────────────────────────────────────────────────────────
// WEEKLY REVIEWS
// ─────────────────────────────────────────────────────────────────────────────

model WeeklyReview {
  id                  String   @id @default(cuid())
  siteId              String
  site                Site     @relation(fields: [siteId], references: [id])
  weekStarting        DateTime
  generatedAt         DateTime @default(now())
  totalJobsCompleted  Int
  totalCostExVat      Float
  complaintsRaised    Int      @default(0)
  complaintsRectified Int      @default(0)
  emailSentAt         DateTime?

  audits WeeklyReviewAudit[]

  @@unique([siteId, weekStarting])
  @@index([siteId])
}

model WeeklyReviewAudit {
  id             String       @id @default(cuid())
  weeklyReviewId String
