// ─────────────────────────────────────────────────────────────────────────────
// SITE
// Extended: geofence, billing terms, account manager, customer contact
// ─────────────────────────────────────────────────────────────────────────────

model Site {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  address        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  // Geofencing
  geofenceLat          Float?
  geofenceLng          Float?
  geofenceRadiusMetres Int?   @default(100)

  // Customer billing config
  billingCycle  BillingCycle @default(WEEKLY)
  paymentTerms  PaymentTerms @default(NET14)
  xeroContactId String?

  // Customer contact (receives timesheet approval + weekly review emails)
  customerContactName  String?
  customerContactEmail String?

  // Account manager from Total Valeting assigned to this site
  accountManagerUserId String?
  accountManager       User?   @relation("AccountManagerSites", fields: [accountManagerUserId], references: [id])

  departments      Department[]
  bookings         Booking[]
  users            User[]
  clockEvents      ClockEvent[]
  timesheets       Timesheet[]
  customerInvoices CustomerInvoice[]
  audits           Audit[]
  weeklyReviews    WeeklyReview[]

  @@index([organisationId])
}

enum BillingCycle {
  WEEKLY
  MONTHLY
}

enum PaymentTerms {
  NET14
  MONTH_END
  MONTH_END_PLUS1
}

// ─────────────────────────────────────────────────────────────────────────────
// DEPARTMENT
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])
  name   String

  bookings     Booking[]
  serviceTypes ServiceType[]

  @@index([siteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Extended: staffType (SITE/SSS), phone, NatWest Bankline fields
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  siteId         String?
  site           Site?        @relation(fields: [siteId], references: [id])
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role
  staffType      StaffType    @default(SITE)
  skills         String[]
  avatarUrl      String?
  phone          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  // NatWest Bankline payroll fields
  bankSortCode      String?
  bankAccountNumber String?
  bankAccountName   String?
  bankReference     String?

  assignedBookings     Booking[]          @relation("AssignedValeter")
  createdBookings      Booking[]          @relation("CreatedBy")
  statusHistory        JobStatusHistory[]
  holidayRequests      HolidayRequest[]
  leaveAllowance       LeaveAllowance?
  clockEvents          ClockEvent[]
  timesheets           Timesheet[]
  payRunLines          PayRunLine[]
  contractorRates      ContractorRate[]
  auditsConducted      Audit[]
  complaintsRaised     Complaint[]        @relation("RaisedBy")
  complaintsRectified  Complaint[]        @relation("RectifiedBy")
  accountManagerSites  Site[]             @relation("AccountManagerSites")
  sentMessages         AccountManagerMessage[] @relation("MessageFrom")
  receivedMessages     AccountManagerMessage[] @relation("MessageTo")

  @@index([organisationId])
  @@index([siteId])
}

enum Role {
  super_admin
  org_admin
  dealership_user
  valeter
}

enum StaffType {
  SITE // Fixed to one site
  SSS  // Site Support Staff — mobile, covers any site
}

